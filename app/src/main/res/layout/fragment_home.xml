<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homeScroll"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream"
    android:clipToPadding="false"
    android:fillViewport="true"
    tools:context=".HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="26dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:id="@+id/ivLogo"
                android:layout_width="230dp"
                android:layout_height="78dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:contentDescription="@string/app_name"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo_mark" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="Resep"
                            android:textColor="#F26B00"
                            android:textSize="28sp"
                            android:textStyle="bold|italic" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="Ku"
                            android:textColor="@color/primary_green"
                            android:textSize="28sp"
                            android:textStyle="bold|italic" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:includeFontPadding="false"
                        android:text="Masak Lezat, Hidup Sehat"
                        android:textColor="@color/primary_green"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/search_bar_stroke"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/setting_notification"
                        android:src="@drawable/ic_bell"
                        app:tint="@color/text_dark" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="11dp"
                        android:layout_marginEnd="9dp"
                        android:background="@drawable/bg_notification_dot" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/home_greeting_prefix"
                android:textColor="@color/text_dark"
                android:textSize="29sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:includeFontPadding="false"
                android:text="@string/home_greeting_accent"
                android:textColor="#E96B12"
                android:textSize="29sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="-18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_spark"
                app:tint="@color/primary_green" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_search" />

            <EditText
                android:id="@+id/etSearchRecipe"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/home_search_hint"
                android:inputType="text"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="@color/text_dark"
                android:textColorHint="#9A918C"
                android:textSize="17sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="-4dp"
            android:layout_marginEnd="-4dp"
            android:layout_marginTop="22dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <LinearLayout
                    android:id="@+id/categoryBreakfast"
                    style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_sun" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_breakfast" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/categoryChicken"
                    style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_chicken" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_chicken" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/categoryDessert"
                    style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_cake" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_dessert" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/categorySeafood"
                    style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_fish" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_seafood" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/categoryHealthy"
                    style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_leaf" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_healthy" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/recommendationCard"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#FFF8E9"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/search_bar_stroke"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_recommendation"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="14dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:id="@+id/recommendationBadge"
                    android:layout_width="0dp"
                    android:layout_height="31dp"
                    android:background="@drawable/bg_badge_orange"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    app:layout_constraintEnd_toStartOf="@+id/ivRecoImage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/home_recommendation_badge"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRecoTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="10dp"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="1dp"
                    android:maxLines="3"
                    android:text="@string/home_recommendation_title"
                    android:textColor="@color/text_on_light_surface"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/ivRecoImage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/recommendationBadge" />

                <TextView
                    android:id="@+id/tvRecoDesc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:ellipsize="end"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:text="@string/home_recommendation_desc"
                    android:textColor="@color/text_muted_on_light_surface"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toStartOf="@+id/ivRecoImage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvRecoTitle" />

                <LinearLayout
                    android:id="@+id/btnViewRecipe"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_orange"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvRecoDesc"
                    app:layout_constraintVertical_bias="1">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/home_view_recipe"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/white" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivRecommendationFavorite"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/ic_heart"
                    app:layout_constraintStart_toEndOf="@id/tvRecoTitle"
                    app:layout_constraintTop_toTopOf="@id/tvRecoTitle"
                    app:tint="#FF9B1A" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivRecoImage"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_soup_chicken_ginger"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_percent="0.88"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.50"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/ivRecoImage"
                    app:layout_constraintStart_toStartOf="@+id/ivRecoImage">

                    <View android:id="@+id/dotRecommendation1" style="@style/HomeCarouselDotActive" />
                    <View android:id="@+id/dotRecommendation2" style="@style/HomeCarouselDotInactive" />
                    <View android:id="@+id/dotRecommendation3" style="@style/HomeCarouselDotInactive" />
                    <View android:id="@+id/dotRecommendation4" style="@style/HomeCarouselDotInactive" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:id="@+id/btnViewAllRecipes"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_flame" />

                <TextView
                    android:id="@+id/tvPopularTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:includeFontPadding="false"
                    android:text="@string/home_popular_title"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/home_view_all"
                    android:textColor="@color/primary_green"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/primary_green" />
            </LinearLayout>
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPopularRecipes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            tools:itemCount="4"
            tools:listitem="@layout/item_recipe_popular" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="22dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_database"
                    app:tint="@color/primary_orange" />

                <TextView
                    android:id="@+id/tvApiRecipesTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:includeFontPadding="false"
                    android:text="@string/home_api_recipes_title"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvApiRecipes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            tools:itemCount="5"
            tools:listitem="@layout/item_recipe_popular" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
