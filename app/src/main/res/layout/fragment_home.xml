<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream"
    android:clipToPadding="false"
    android:fillViewport="true"
    tools:context=".HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="26dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_marginTop="18dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="164dp"
                android:layout_height="78dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:scaleType="fitStart"
                android:src="@drawable/logo" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/search_bar_stroke"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/setting_notification"
                        android:src="@drawable/ic_bell"
                        app:tint="#3C2418" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="11dp"
                        android:layout_marginEnd="9dp"
                        android:background="@drawable/bg_notification_dot" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/home_greeting_prefix"
                android:textColor="#2B1309"
                android:textSize="29sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:includeFontPadding="false"
                android:text="@string/home_greeting_accent"
                android:textColor="#E96B12"
                android:textSize="29sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="-18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_spark"
                app:tint="@color/primary_green" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_search" />

            <EditText
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/home_search_hint"
                android:inputType="text"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="@color/text_dark"
                android:textColorHint="#9A918C"
                android:textSize="17sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="-4dp"
            android:layout_marginEnd="-4dp"
            android:layout_marginTop="22dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <LinearLayout style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_sun" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_breakfast" />
                </LinearLayout>

                <LinearLayout style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_chicken" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_chicken" />
                </LinearLayout>

                <LinearLayout style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_cake" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_dessert" />
                </LinearLayout>

                <LinearLayout style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_fish" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_seafood" />
                </LinearLayout>

                <LinearLayout style="@style/HomeCategoryPill">
                    <ImageView style="@style/HomeCategoryIcon" android:src="@drawable/ic_leaf" />
                    <TextView style="@style/HomeCategoryText" android:text="@string/home_category_healthy" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#FFF8E9"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/search_bar_stroke"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_recommendation"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="0dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:id="@+id/recommendationBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_badge_orange"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:includeFontPadding="false"
                        android:text="@string/home_recommendation_badge"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRecoTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="1dp"
                    android:text="@string/home_recommendation_title"
                    android:textColor="#2B1309"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/ivRecoImage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/recommendationBadge" />

                <TextView
                    android:id="@+id/tvRecoDesc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/home_recommendation_desc"
                    android:textColor="#655B56"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toStartOf="@+id/ivRecoImage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvRecoTitle" />

                <LinearLayout
                    android:id="@+id/btnViewRecipe"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_button_orange"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvRecoDesc">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/home_view_recipe"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="10dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/white" />
                </LinearLayout>

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/ic_heart"
                    app:layout_constraintStart_toEndOf="@id/tvRecoTitle"
                    app:layout_constraintTop_toTopOf="@id/tvRecoTitle"
                    app:tint="#FF9B1A" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivRecoImage"
                    android:layout_width="178dp"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_soup_chicken_ginger"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MediumComponent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/ivRecoImage"
                    app:layout_constraintStart_toStartOf="@+id/ivRecoImage">

                    <View style="@style/HomeCarouselDotActive" />
                    <View style="@style/HomeCarouselDotInactive" />
                    <View style="@style/HomeCarouselDotInactive" />
                    <View style="@style/HomeCarouselDotInactive" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_flame" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:includeFontPadding="false"
                    android:text="@string/home_popular_title"
                    android:textColor="#2B1309"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/home_view_all"
                    android:textColor="@color/primary_green"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/primary_green" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/llPopularRecipes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <include layout="@layout/item_recipe_popular_nasi" />
            <include layout="@layout/item_recipe_popular_ayam" />
            <include layout="@layout/item_recipe_popular_pancake" />
            <include layout="@layout/item_recipe_popular_salad" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
