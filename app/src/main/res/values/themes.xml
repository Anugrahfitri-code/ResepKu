<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ResepKu" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_orange</item>
        <item name="android:windowBackground">@color/background_cream</item>
    </style>

    <style name="Theme.ResepKu" parent="Base.Theme.ResepKu" />

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.ResepKu.SettingsCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/search_bar_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="SettingsSectionContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SettingsHeaderRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="SettingsHeaderIcon">
        <item name="android:layout_width">23dp</item>
        <item name="android:layout_height">23dp</item>
        <item name="tint">@color/primary_orange</item>
    </style>

    <style name="SettingsHeaderTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">14dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">#21100A</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SettingsItemRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="SettingsItemRowSmall" parent="SettingsItemRow">
        <item name="android:layout_height">38dp</item>
    </style>

    <style name="SettingsItemIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="tint">#4B3024</item>
    </style>

    <style name="SettingsItemIconSmall" parent="SettingsItemIcon">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
    </style>

    <style name="SettingsItemTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">#352A25</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="SettingsItemTitleSmall" parent="SettingsItemTitle">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="SettingsItemValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">#5F5651</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="SettingsItemValuePlain" parent="SettingsItemValue">
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:layout_marginEnd">0dp</item>
    </style>

    <style name="SettingsChevron">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:src">@drawable/ic_chevron_right</item>
        <item name="tint">#2F190F</item>
    </style>

    <style name="SettingsChevronSmall" parent="SettingsChevron">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
    </style>

    <style name="SettingsDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">0dp</item>
        <item name="android:layout_marginEnd">0dp</item>
        <item name="android:background">@color/divider_warm</item>
    </style>

    <style name="SettingsSwitch">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="thumbTint">@color/switch_thumb_tint</item>
        <item name="trackTint">@color/switch_track_tint</item>
    </style>

    <style name="Widget.ResepKu.BottomNavigation.ActiveIndicator" parent="">
        <item name="android:color">@color/light_orange</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.MediumComponent</item>
    </style>

    <style name="HomeCategoryPill">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:background">@drawable/bg_category_pill</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">18dp</item>
    </style>

    <style name="HomeCategoryIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <style name="HomeCategoryText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">9dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">#2F231E</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="HomeCarouselDotActive">
        <item name="android:layout_width">9dp</item>
        <item name="android:layout_height">9dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_dot_orange</item>
    </style>

    <style name="HomeCarouselDotInactive" parent="HomeCarouselDotActive">
        <item name="android:layout_width">8dp</item>
        <item name="android:layout_height">8dp</item>
        <item name="android:background">@drawable/bg_dot_white</item>
    </style>

    <style name="RecipeCardTitle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">18dp</item>
        <item name="android:layout_marginTop">18dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">#2B1309</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="layout_constraintEnd_toStartOf">@id/ivFavorite</item>
        <item name="layout_constraintStart_toEndOf">@id/ivRecipe</item>
        <item name="layout_constraintTop_toTopOf">parent</item>
    </style>

    <style name="RecipeCardTagOrange">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:background">@drawable/bg_recipe_tag_orange</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/primary_orange</item>
        <item name="android:textSize">12sp</item>
        <item name="layout_constraintStart_toStartOf">@id/tvRecipeName</item>
        <item name="layout_constraintTop_toBottomOf">@id/tvRecipeName</item>
    </style>

    <style name="RecipeCardTagPink" parent="RecipeCardTagOrange">
        <item name="android:background">@drawable/bg_recipe_tag_pink</item>
        <item name="android:textColor">#EE5173</item>
    </style>

    <style name="RecipeCardTagGreen" parent="RecipeCardTagOrange">
        <item name="android:background">@drawable/bg_recipe_tag_green</item>
        <item name="android:textColor">@color/primary_green</item>
    </style>

    <style name="RecipeMetaRow">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="layout_constraintBottom_toBottomOf">parent</item>
        <item name="layout_constraintEnd_toEndOf">parent</item>
        <item name="layout_constraintStart_toStartOf">@id/tvRecipeName</item>
        <item name="layout_constraintTop_toBottomOf">@id/tvCategory</item>
    </style>

    <style name="RecipeMetaIconClock">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:src">@drawable/ic_clock</item>
        <item name="tint">#7B736F</item>
    </style>

    <style name="RecipeMetaIconLevel">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:src">@drawable/ic_level</item>
    </style>

    <style name="RecipeMetaText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">7dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">#7B736F</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="RecipeCardHeart">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginEnd">18dp</item>
        <item name="android:src">@drawable/ic_heart</item>
        <item name="tint">#FF5A00</item>
        <item name="layout_constraintBottom_toBottomOf">parent</item>
        <item name="layout_constraintEnd_toEndOf">parent</item>
        <item name="layout_constraintTop_toTopOf">parent</item>
    </style>
</resources>
